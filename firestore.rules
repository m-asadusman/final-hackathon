rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone can read, only the owner can write
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Posts: anyone can read, authenticated users can create,
    // only the owner can update (e.g. mark solved)
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Messages: authenticated users can read their own, authenticated can create
    match /messages/{msgId} {
      allow read: if request.auth != null &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid);
      allow create: if request.auth != null;
    }

    // Notifications: only the target user can read/update
    match /notifications/{notifId} {
      allow read, update: if request.auth != null &&
        resource.data.uid == request.auth.uid;
      allow create: if request.auth != null;
    }
  }
}
